<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Blog do Jean</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
    background: #f7f6f3;
    color: #2b2b2b;
    line-height: 1.5;
    padding: 24px 16px 60px;
  }
  header {
    max-width: 700px;
    margin: 0 auto 24px;
    text-align: center;
  }
  header h1 {
    font-size: 2rem;
    color: #3a3a3a;
  }
  header p {
    color: #777;
    margin-top: 4px;
    font-size: 0.95rem;
  }
  .filters {
    max-width: 700px;
    margin: 0 auto 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }
  .filters button {
    border: 1px solid #ccc;
    background: #fff;
    color: #555;
    padding: 6px 14px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.85rem;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .filters button:hover {
    border-color: #999;
  }
  .filters button.active {
    background: #4a6d5c;
    border-color: #4a6d5c;
    color: #fff;
  }
  .posts {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .post {
    background: #fff;
    border: 1px solid #e5e3de;
    border-radius: 10px;
    padding: 18px 20px;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .post.hidden {
    display: none;
  }
  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 8px;
  }
  .post h2 {
    font-size: 1.15rem;
    color: #2b2b2b;
  }
  .tag {
    font-size: 0.72rem;
    background: #eef1ee;
    color: #4a6d5c;
    padding: 3px 10px;
    border-radius: 12px;
    font-weight: 600;
    white-space: nowrap;
  }
  .date {
    font-size: 0.78rem;
    color: #999;
  }
  .post p {
    font-size: 0.93rem;
    color: #444;
  }
</style>
</head>
<body>

<header>
  <h1>Blog do Jean</h1>
  <p>Anotações e desabafos sobre a escola, matéria por matéria.</p>
</header>

<div class="filters" id="filters"></div>

<div class="posts" id="posts"></div>

<script>
const posts = [
  {
    titulo: "Química",
    categoria: "Química",
    data: "07 Jul 2026",
    texto: "É uma matéria bem interessante, mas confusa — precisa de um raciocínio avançado para entender a maioria dos conteúdos. O professor, no entanto, é muito bom: explica direitinho e consegue fazer a turma aprender de verdade."
  },
  {
    titulo: "Artes",
    categoria: "Artes",
    data: "07 Jul 2026",
    texto: "Gosto da matéria, mas nunca fui bom de desenho, então sempre tento evitar ao máximo. O professor é bem legal, brinca com a sala e sabe passar o conteúdo de um jeito bom — às vezes até parece aula de história."
  },
  {
    titulo: "Matemática",
    categoria: "Matemática",
    data: "07 Jul 2026",
    texto: "Sinceramente, esse ano não está sendo muito bom. Estou com dificuldade para aprender a matéria, e o professor me dá um pouco de medo — quando fazem perguntas, às vezes ele fica bravo ou irritado."
  },
  {
    titulo: "Biologia",
    categoria: "Biologia",
    data: "07 Jul 2026",
    texto: "Uma matéria muito interessante. O professor se esforça bastante, mas a turma nem sempre ajuda. De qualquer forma, gosto bastante dele."
  },
  {
    titulo: "Educação Física",
    categoria: "Educação Física",
    data: "07 Jul 2026",
    texto: "Não tem muito o que falar. A professora é boa, mas não damos tanta matéria — a maioria das aulas é na quadra mesmo."
  },
  {
    titulo: "Português",
    categoria: "Português",
    data: "07 Jul 2026",
    texto: "Não mudou muito em relação aos anos anteriores, com a maioria das aulas focadas em redação. O professor é legal, mas se irrita fácil com a turma."
  },
  {
    titulo: "Inglês",
    categoria: "Inglês",
    data: "07 Jul 2026",
    texto: "Estou gostando bastante! Fazemos várias atividades, tanto no Inglês Paraná quanto no caderno, e o professor é gente boa — sabe ensinar de um jeito divertido."
  }
];

const categorias = ["Todos", ...new Set(posts.map(p => p.categoria))];
const filtersEl = document.getElementById("filters");
const postsEl = document.getElementById("posts");

categorias.forEach(cat => {
  const btn = document.createElement("button");
  btn.textContent = cat;
  if (cat === "Todos") btn.classList.add("active");
  btn.addEventListener("click", () => {
    document.querySelectorAll(".filters button").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    filtrar(cat);
  });
  filtersEl.appendChild(btn);
});

function renderPosts() {
  postsEl.innerHTML = "";
  posts.forEach(p => {
    const div = document.createElement("div");
    div.className = "post";
    div.dataset.categoria = p.categoria;
    div.innerHTML = `
      <div class="post-header">
        <h2>${p.titulo}</h2>
        <span class="tag">${p.categoria}</span>
      </div>
      <div class="date">${p.data}</div>
      <p>${p.texto}</p>
    `;
    postsEl.appendChild(div);
  });
}

function filtrar(cat) {
  document.querySelectorAll(".post").forEach(post => {
    if (cat === "Todos" || post.dataset.categoria === cat) {
      post.classList.remove("hidden");
    } else {
      post.classList.add("hidden");
    }
  });
}

renderPosts();
</script>

</body>
</html>
